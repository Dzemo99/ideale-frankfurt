---
import type { ServiceIcon } from '../../data/services';

export interface Props {
  icon: ServiceIcon;
  class?: string;
}

const { icon, class: extra = 'h-7 w-7' } = Astro.props;
---
<svg
  class={extra}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  {icon === 'window' && (
    <>
      <rect x="3" y="3" width="18" height="18" rx="1" />
      <line x1="12" y1="3" x2="12" y2="21" />
      <line x1="3" y1="12" x2="21" y2="12" />
    </>
  )}
  {icon === 'building' && (
    <>
      <rect x="4" y="2" width="16" height="20" rx="1" />
      <line x1="9" y1="6" x2="9" y2="6.01" />
      <line x1="15" y1="6" x2="15" y2="6.01" />
      <line x1="9" y1="10" x2="9" y2="10.01" />
      <line x1="15" y1="10" x2="15" y2="10.01" />
      <line x1="9" y1="14" x2="9" y2="14.01" />
      <line x1="15" y1="14" x2="15" y2="14.01" />
      <path d="M10 22v-4h4v4" />
    </>
  )}
  {icon === 'briefcase' && (
    <>
      <rect x="2" y="7" width="20" height="14" rx="2" />
      <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2" />
      <line x1="2" y1="13" x2="22" y2="13" />
    </>
  )}
  {icon === 'droplet' && (
    <path d="M12 2.5s-6 7-6 11.5a6 6 0 0 0 12 0c0-4.5-6-11.5-6-11.5z" />
  )}
  {icon === 'sun' && (
    <>
      <circle cx="12" cy="12" r="4" />
      <line x1="12" y1="2" x2="12" y2="4" />
      <line x1="12" y1="20" x2="12" y2="22" />
      <line x1="4.93" y1="4.93" x2="6.34" y2="6.34" />
      <line x1="17.66" y1="17.66" x2="19.07" y2="19.07" />
      <line x1="2" y1="12" x2="4" y2="12" />
      <line x1="20" y1="12" x2="22" y2="12" />
      <line x1="4.93" y1="19.07" x2="6.34" y2="17.66" />
      <line x1="17.66" y1="6.34" x2="19.07" y2="4.93" />
    </>
  )}
  {icon === 'hammer' && (
    <>
      <path d="M15 12l-8.5 8.5a2.12 2.12 0 0 1-3-3L12 9" />
      <path d="M17.64 15L22 10.64" />
      <path d="M20.91 11.7l-1.25-1.25c-.6-.6-.93-1.4-.93-2.25v-.86L16.01 4.6a5.56 5.56 0 0 0-3.94-1.64H9l.92.82A6.18 6.18 0 0 1 12 8.4v1.56l2 2h2.47l2.26 1.91" />
    </>
  )}
  {icon === 'stairs' && (
    <path d="M3 21h4v-4h4v-4h4V9h4V5h3" />
  )}
  {icon === 'factory' && (
    <>
      <path d="M2 20h20" />
      <path d="M3 20V10l5 4V10l5 4V10l5 4V20" />
      <line x1="9" y1="20" x2="9" y2="16" />
      <line x1="14" y1="20" x2="14" y2="16" />
    </>
  )}
  {icon === 'cross' && (
    <>
      <line x1="12" y1="4" x2="12" y2="20" />
      <line x1="4" y1="12" x2="20" y2="12" />
    </>
  )}
  {icon === 'bed' && (
    <>
      <path d="M2 20V8h11a5 5 0 0 1 5 5v7" />
      <path d="M2 14h20" />
      <path d="M22 20v-6" />
      <circle cx="7" cy="11" r="2" />
    </>
  )}
  {icon === 'rug' && (
    <>
      <rect x="3" y="6" width="18" height="12" rx="1" />
      <line x1="3" y1="9" x2="21" y2="9" />
      <line x1="3" y1="15" x2="21" y2="15" />
      <line x1="3" y1="4" x2="6" y2="6" />
      <line x1="21" y1="4" x2="18" y2="6" />
      <line x1="3" y1="20" x2="6" y2="18" />
      <line x1="21" y1="20" x2="18" y2="18" />
    </>
  )}
  {icon === 'sparkles' && (
    <>
      <path d="M12 3l1.9 5.1L19 10l-5.1 1.9L12 17l-1.9-5.1L5 10l5.1-1.9L12 3z" />
      <path d="M19 17l.8 2.2L22 20l-2.2.8L19 23l-.8-2.2L16 20l2.2-.8L19 17z" />
    </>
  )}
</svg>
