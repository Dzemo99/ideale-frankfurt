---
import { Image } from 'astro:assets';
import type { Service } from '../../data/services';
import ServiceIcon from './ServiceIcon.astro';

export interface Props {
  service: Service;
}

const { service } = Astro.props;
---
<article class="group relative flex h-full flex-col overflow-hidden rounded-2xl border border-white/10 bg-white/[0.03] backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:border-ig-emerald/40 hover:bg-white/[0.06]">
  {service.image && (
    <div class="relative aspect-[16/10] overflow-hidden">
      <Image
        src={service.image}
        alt={`${service.title} — Beispiel`}
        loading="lazy"
        decoding="async"
        widths={[320, 480, 640]}
        sizes="(min-width: 1280px) 280px, (min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
      <div aria-hidden="true" class="absolute inset-0 bg-gradient-to-t from-ig-ink/80 via-ig-ink/20 to-transparent"></div>
    </div>
  )}

  <div class="flex flex-1 flex-col p-6 md:p-7">
    <div class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl border border-white/10 bg-white/[0.04] text-ig-emerald transition-all duration-300 group-hover:scale-110 group-hover:border-ig-emerald/40 group-hover:bg-ig-emerald/10">
      <ServiceIcon icon={service.icon} />
    </div>
    <h3 class="h3-display mb-2 text-white">{service.title}</h3>
    <p class="text-sm leading-relaxed text-white/60">{service.short}</p>
  </div>

  <span aria-hidden="true" class="absolute right-5 top-5 text-white/20 transition-all duration-300 group-hover:translate-x-1 group-hover:text-ig-emerald">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="5" y1="12" x2="19" y2="12" />
      <polyline points="12 5 19 12 12 19" />
    </svg>
  </span>
</article>
