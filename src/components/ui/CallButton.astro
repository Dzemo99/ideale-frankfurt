---
import { SITE } from '../../data/site';

export interface Props {
  variant?: 'primary' | 'secondary' | 'plain';
  size?: 'md' | 'lg';
  label?: string;
  showNumber?: boolean;
  class?: string;
}

const {
  variant = 'primary',
  size = 'md',
  label = 'Jetzt anrufen',
  showNumber = true,
  class: extra = '',
} = Astro.props;

const base =
  variant === 'primary'
    ? 'btn-primary'
    : variant === 'secondary'
    ? 'btn-secondary'
    : 'inline-flex items-center gap-2 font-semibold text-ig-ink hover:text-ig-deep transition-colors';

const sizeClass = size === 'lg' ? 'px-8 py-4 text-lg' : '';
---
<a
  href={SITE.phoneLink}
  class={`${base} ${sizeClass} ${extra}`.trim()}
  data-track="phone_click"
  aria-label={`${label}: ${SITE.phoneDisplay}`}
>
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
  </svg>
  <span>
    {label}{showNumber && (
      <span class="hidden sm:inline"> · <span class="font-mono tracking-tight">{SITE.phoneDisplay}</span></span>
    )}
  </span>
</a>
