---
import CallButton from '../ui/CallButton.astro';
import WhatsAppButton from '../ui/WhatsAppButton.astro';
---
<section class="relative isolate overflow-hidden bg-ig-ink py-24 text-white on-dark md:py-32">
  <div aria-hidden="true" class="absolute inset-0 -z-10 bg-mesh-hero"></div>
  <div aria-hidden="true" class="absolute inset-x-0 top-0 -z-10 h-px bg-gradient-to-r from-transparent via-white/15 to-transparent"></div>

  <div class="container-ig text-center">
    <span class="eyebrow">Bereit?</span>
    <h2 class="h2-display mt-4 text-balance text-white">
      Bereit für saubere Räume in Frankfurt?
    </h2>
    <p class="lead-dark mt-5 mx-auto max-w-2xl">
      Ein Anruf, ein kostenloses Vor-Ort-Gespräch, ein Festpreis. Mehr braucht es nicht.
    </p>

    <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-4">
      <CallButton size="lg" />
      <WhatsAppButton size="lg" />
    </div>
  </div>
</section>
