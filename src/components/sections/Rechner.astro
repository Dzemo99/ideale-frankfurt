---
// Interaktiver Anfrage-Rechner. Submit geht an Netlify Form "frankfurt-rechner".
// Hidden detection-form ist in index.astro hinterlegt.
const intervals = [
  { value: 'einmalig',     label: 'Einmalig',      hint: 'Einzeltermin' },
  { value: 'woechentlich', label: 'Wöchentlich',   hint: '1× pro Woche' },
  { value: '2x-woche',     label: '2× wöchentlich', hint: 'Hochfrequenz' },
  { value: 'monatlich',    label: 'Monatlich',     hint: '1× pro Monat' },
];
---
<section id="rechner" class="relative isolate overflow-hidden bg-ig-ink py-24 text-white on-dark md:py-32">
  <!-- Background mesh -->
  <div aria-hidden="true" class="absolute inset-0 -z-10 bg-mesh-rechner"></div>
  <div aria-hidden="true" class="absolute inset-x-0 top-0 -z-10 h-px bg-gradient-to-r from-transparent via-white/15 to-transparent"></div>

  <div class="container-ig">

    <div class="mx-auto max-w-2xl text-center">
      <span class="eyebrow">Preis berechnen</span>
      <h2 class="h2-display mt-4 text-balance text-white">
        Ihr unverbindliches Angebot — in zwei Minuten.
      </h2>
      <p class="lead-dark mt-5">
        Sagen Sie uns, worum es geht. Wir melden uns am selben Werktag mit einem Festpreis.
      </p>
    </div>

    <form
      id="rechner-form"
      name="frankfurt-rechner"
      method="POST"
      data-netlify="true"
      data-netlify-honeypot="bot-field"
      action="/danke"
      class="mx-auto mt-14 max-w-4xl rounded-2xl border border-white/10 bg-white/[0.03] p-6 backdrop-blur-md md:p-10"
    >
      <input type="hidden" name="form-name" value="frankfurt-rechner" />
      <input type="hidden" name="source" value="frankfurt-rechner" />
      <p class="hidden">
        <label>Nicht ausfüllen: <input name="bot-field" /></label>
      </p>

      <!-- Objektname -->
      <div class="grid gap-6 md:grid-cols-2">
        <label class="block">
          <span class="block text-sm font-semibold text-white">
            Objektname / Bezeichnung
          </span>
          <input
            type="text"
            name="objekt"
            placeholder="z.B. Büro Westend, Praxis Bornheim"
            class="input-glass mt-2"
          />
        </label>

        <!-- Quadratmeter Slider -->
        <div>
          <div class="flex items-baseline justify-between">
            <span class="text-sm font-semibold text-white">Quadratmeter</span>
            <span class="font-display text-2xl font-bold text-ig-emerald" id="qm-display">120</span>
          </div>
          <input
            type="range"
            id="qm-slider"
            name="quadratmeter"
            min="20"
            max="2000"
            step="10"
            value="120"
            class="slider-emerald mt-3"
            aria-label="Quadratmeter"
          />
          <div class="mt-1 flex justify-between text-xs text-white/45">
            <span>20 m²</span>
            <span>2000+ m²</span>
          </div>
        </div>
      </div>

      <!-- Stepper: Räume + Sanitär -->
      <div class="mt-8 grid gap-6 md:grid-cols-2">
        <div class="rounded-xl border border-white/10 bg-white/[0.03] p-5">
          <div class="flex items-center justify-between gap-4">
            <div>
              <div class="text-sm font-semibold text-white">Räume</div>
              <div class="text-xs text-white/50">Anzahl der zu reinigenden Räume</div>
            </div>
            <div class="flex items-center gap-3">
              <button
                type="button"
                data-stepper="raeume"
                data-action="dec"
                class="flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-white/[0.04] text-white transition-all hover:border-ig-emerald hover:bg-ig-emerald/10 active:scale-95"
                aria-label="Räume verringern"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12" /></svg>
              </button>
              <span
                id="raeume-display"
                class="w-10 text-center font-display text-2xl font-bold text-white tabular-nums"
              >3</span>
              <input type="hidden" id="raeume-input" name="raeume" value="3" />
              <button
                type="button"
                data-stepper="raeume"
                data-action="inc"
                class="flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-white/[0.04] text-white transition-all hover:border-ig-emerald hover:bg-ig-emerald/10 active:scale-95"
                aria-label="Räume erhöhen"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
              </button>
            </div>
          </div>
        </div>

        <div class="rounded-xl border border-white/10 bg-white/[0.03] p-5">
          <div class="flex items-center justify-between gap-4">
            <div>
              <div class="text-sm font-semibold text-white">WC / Sanitär</div>
              <div class="text-xs text-white/50">Anzahl der Sanitärbereiche</div>
            </div>
            <div class="flex items-center gap-3">
              <button
                type="button"
                data-stepper="sanitaer"
                data-action="dec"
                class="flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-white/[0.04] text-white transition-all hover:border-ig-emerald hover:bg-ig-emerald/10 active:scale-95"
                aria-label="Sanitär verringern"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12" /></svg>
              </button>
              <span
                id="sanitaer-display"
                class="w-10 text-center font-display text-2xl font-bold text-white tabular-nums"
              >1</span>
              <input type="hidden" id="sanitaer-input" name="sanitaer" value="1" />
              <button
                type="button"
                data-stepper="sanitaer"
                data-action="inc"
                class="flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-white/[0.04] text-white transition-all hover:border-ig-emerald hover:bg-ig-emerald/10 active:scale-95"
                aria-label="Sanitär erhöhen"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Intervall — Bento Cards -->
      <fieldset class="mt-8">
        <legend class="block text-sm font-semibold text-white">Reinigungsintervall</legend>
        <input type="hidden" id="intervall-input" name="intervall" value="woechentlich" />
        <div class="mt-3 grid grid-cols-2 gap-3 md:grid-cols-4">
          {intervals.map((opt) => (
            <button
              type="button"
              data-intervall={opt.value}
              class={`group relative flex flex-col items-start gap-1 rounded-xl border bg-white/[0.03] p-4 text-left transition-all hover:bg-white/[0.06] hover:-translate-y-0.5 ${opt.value === 'woechentlich' ? 'border-ig-emerald ring-1 ring-ig-emerald/40' : 'border-white/10'}`}
              aria-pressed={opt.value === 'woechentlich' ? 'true' : 'false'}
            >
              <span class="font-display text-base font-semibold text-white">{opt.label}</span>
              <span class="text-xs text-white/55">{opt.hint}</span>
              <span class="absolute right-3 top-3 h-4 w-4 rounded-full border border-white/15 transition-all group-aria-pressed:border-ig-emerald group-aria-pressed:bg-ig-emerald">
                <span class="absolute inset-0.5 hidden rounded-full bg-white group-aria-pressed:block"></span>
              </span>
            </button>
          ))}
        </div>
      </fieldset>

      <!-- Kontaktdaten -->
      <div class="mt-10 grid gap-5 md:grid-cols-3">
        <label class="block">
          <span class="block text-sm font-semibold text-white">Name <span class="text-ig-danger">*</span></span>
          <input type="text" name="name" required autocomplete="name" class="input-glass mt-2" />
        </label>
        <label class="block">
          <span class="block text-sm font-semibold text-white">Telefon <span class="text-ig-danger">*</span></span>
          <input type="tel" name="telefon" required autocomplete="tel" inputmode="tel" class="input-glass mt-2" />
        </label>
        <label class="block">
          <span class="block text-sm font-semibold text-white">E-Mail <span class="text-ig-danger">*</span></span>
          <input type="email" name="email" required autocomplete="email" class="input-glass mt-2" />
        </label>
      </div>

      <label class="mt-6 flex items-start gap-3 text-sm text-white/70">
        <input type="checkbox" required name="datenschutz" class="mt-1 h-4 w-4 rounded border-white/20 bg-white/10 text-ig-emerald focus:ring-ig-emerald" />
        <span>
          Ich habe die <a href="/datenschutz" class="underline hover:text-ig-emerald">Datenschutzerklärung</a> gelesen und stimme der Verarbeitung meiner Daten zur Bearbeitung meiner Anfrage zu.
        </span>
      </label>

      <button
        type="submit"
        id="rechner-submit"
        class="btn-primary mt-8 w-full py-4 text-base md:w-auto md:px-12"
        data-form="rechner"
      >
        <span data-state="idle" class="inline-flex items-center gap-2">
          Festpreis anfordern
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </span>
        <span data-state="loading" class="hidden items-center gap-2">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" class="animate-spin" aria-hidden="true">
            <path d="M21 12a9 9 0 1 1-6.219-8.56" />
          </svg>
          Wird gesendet…
        </span>
      </button>

      <p class="mt-4 text-center text-xs text-white/40 md:text-left">
        Wir kalkulieren auf Basis Ihrer Angaben einen Festpreis. Kein automatischer Online-Preis.
      </p>
    </form>
  </div>
</section>

<script>
  // Slider live-display
  const qmSlider = document.getElementById('qm-slider') as HTMLInputElement | null;
  const qmDisplay = document.getElementById('qm-display');
  if (qmSlider && qmDisplay) {
    const update = () => {
      const v = parseInt(qmSlider.value, 10);
      qmDisplay.textContent = v >= 2000 ? '2000+' : `${v}`;
    };
    qmSlider.addEventListener('input', update);
    update();
  }

  // Stepper (+/-) with min/max
  const stepperConfig: Record<string, { min: number; max: number }> = {
    raeume: { min: 1, max: 50 },
    sanitaer: { min: 0, max: 20 },
  };
  document.querySelectorAll<HTMLButtonElement>('[data-stepper]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.stepper!;
      const action = btn.dataset.action!;
      const display = document.getElementById(`${key}-display`);
      const input = document.getElementById(`${key}-input`) as HTMLInputElement | null;
      if (!display || !input) return;
      const cfg = stepperConfig[key];
      let val = parseInt(input.value, 10);
      val = action === 'inc' ? Math.min(cfg.max, val + 1) : Math.max(cfg.min, val - 1);
      input.value = String(val);
      display.textContent = String(val);
    });
  });

  // Intervall bento-cards
  const intervallInput = document.getElementById('intervall-input') as HTMLInputElement | null;
  const cards = document.querySelectorAll<HTMLButtonElement>('[data-intervall]');
  cards.forEach((card) => {
    card.addEventListener('click', () => {
      if (!intervallInput) return;
      intervallInput.value = card.dataset.intervall!;
      cards.forEach((c) => {
        const active = c === card;
        c.setAttribute('aria-pressed', String(active));
        if (active) {
          c.classList.add('border-ig-emerald', 'ring-1', 'ring-ig-emerald/40');
          c.classList.remove('border-white/10');
        } else {
          c.classList.remove('border-ig-emerald', 'ring-1', 'ring-ig-emerald/40');
          c.classList.add('border-white/10');
        }
      });
    });
  });

  // Submit loading state
  const form = document.getElementById('rechner-form') as HTMLFormElement | null;
  const submit = document.getElementById('rechner-submit') as HTMLButtonElement | null;
  if (form && submit) {
    form.addEventListener('submit', () => {
      if (!form.checkValidity()) return;
      const idle = submit.querySelector('[data-state="idle"]');
      const loading = submit.querySelector('[data-state="loading"]');
      idle?.classList.add('hidden');
      loading?.classList.remove('hidden');
      loading?.classList.add('inline-flex');
      submit.disabled = true;
      submit.classList.add('cursor-wait', 'opacity-90');
    });
  }
</script>
