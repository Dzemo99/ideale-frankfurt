---
import { Image } from 'astro:assets';
import { SITE } from '../../data/site';
import heroTeam from '../../assets/images/hero-team.jpg';

// Hero submits to the same Netlify form as the deep contact form (`frankfurt-anfrage`)
// so leads land in one place. `source=hero` distinguishes origin in Netlify exports.
---
<section
  class="relative isolate overflow-hidden bg-ig-ink text-white on-dark"
  aria-labelledby="hero-headline"
>
  <!-- Team photo as hero background -->
  <Image
    src={heroTeam}
    alt=""
    role="presentation"
    loading="eager"
    fetchpriority="high"
    widths={[768, 1280, 1920]}
    sizes="100vw"
    class="absolute inset-0 -z-20 h-full w-full object-cover object-center"
  />
  <!-- Dark overlay to keep text readable -->
  <div aria-hidden="true" class="absolute inset-0 -z-10 bg-ig-ink/75"></div>

  <!-- Mesh / radial glow background -->
  <div aria-hidden="true" class="absolute inset-0 -z-10 bg-mesh-hero opacity-80"></div>

  <!-- Subtle grid overlay for depth (very low opacity) -->
  <div aria-hidden="true" class="absolute inset-0 -z-10 opacity-[0.04]">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="hero-grid" width="56" height="56" patternUnits="userSpaceOnUse">
          <path d="M 56 0 L 0 0 0 56" fill="none" stroke="white" stroke-width="0.5" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#hero-grid)" />
    </svg>
  </div>

  <!-- Soft top vignette to anchor the header -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-32 bg-gradient-to-b from-black/30 to-transparent"></div>

  <div class="container-ig grid grid-cols-1 items-center gap-y-12 pt-20 pb-24 md:gap-y-14 md:pt-28 md:pb-32 lg:grid-cols-[50%_45%] lg:gap-y-0 lg:justify-between lg:pt-32 lg:pb-36">

    <!-- LEFT — Value Proposition -->
    <div class="fx-stagger min-w-0">
      <div>
        <span class="eyebrow">Frankfurt · Rhein-Main</span>
      </div>

      <h1 id="hero-headline" class="mt-5 font-display font-bold tracking-tight text-balance text-white text-4xl leading-[1.08] md:text-5xl lg:text-[2.25rem] xl:text-[2.5rem] 2xl:text-[2.75rem]">
        <span class="whitespace-nowrap">Gebäudereinigung in Frankfurt</span> —
        <span class="text-ig-emerald">verlässlich, versichert, festgepreist.</span>
      </h1>

      <p class="mt-7 max-w-xl text-lg leading-relaxed text-ig-mute md:text-xl">
        Professionelle Reinigung für Unternehmen, Hausverwaltungen und Privatkunden im Großraum Frankfurt.
        Eigenes Team, klare Festpreise, 5 Mio. EUR Betriebshaftpflicht.
      </p>

      <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:gap-4">
        <a
          href={SITE.phoneLink}
          class="btn-primary px-8 py-4 text-base"
          data-track="phone_click"
          aria-label={`Jetzt anrufen: ${SITE.phoneDisplay}`}
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
          </svg>
          <span>Jetzt anrufen</span>
        </a>
        <a href="#rechner" class="btn-secondary-dark btn-glow px-8 py-4 text-base">
          Preis berechnen
        </a>
      </div>

      <ul class="mt-12 flex flex-wrap items-center gap-x-7 gap-y-3 text-sm text-white/70">
        <li class="flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-ig-emerald" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
          </svg>
          5 Mio. EUR versichert
        </li>
        <li class="flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-ig-emerald" aria-hidden="true">
            <polyline points="20 6 9 17 4 12" />
          </svg>
          Festpreise statt Stundenabrechnung
        </li>
        <li class="flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-ig-emerald" aria-hidden="true">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
            <circle cx="9" cy="7" r="4" />
            <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
            <path d="M16 3.13a4 4 0 0 1 0 7.75" />
          </svg>
          Eigenes Team
        </li>
      </ul>
    </div>

    <!-- RIGHT — Glassmorphism Schnellanfrage -->
    <div class="fx-stagger relative min-w-0">
      <!-- Subtle glow behind form -->
      <div aria-hidden="true" class="absolute -inset-4 -z-10 rounded-[2rem] bg-ig-emerald/10 opacity-50 blur-2xl"></div>

      <form
        name="frankfurt-anfrage"
        method="POST"
        data-netlify="true"
        data-netlify-honeypot="bot-field"
        action="/danke"
        class="relative rounded-2xl border border-white/10 bg-white/[0.04] p-6 backdrop-blur-xl md:p-8"
      >
        <input type="hidden" name="form-name" value="frankfurt-anfrage" />
        <input type="hidden" name="source" value="hero" />
        <p class="hidden">
          <label>Nicht ausfüllen: <input name="bot-field" /></label>
        </p>

        <div class="mb-6">
          <div class="text-xs font-semibold uppercase tracking-[0.18em] text-ig-emerald">Schnellanfrage</div>
          <h2 class="mt-2 font-display text-2xl font-semibold tracking-tight text-white">
            Antwort am selben Werktag.
          </h2>
        </div>

        <div class="space-y-3">
          <label class="block">
            <span class="sr-only">Name</span>
            <input
              type="text"
              name="name"
              required
              autocomplete="name"
              placeholder="Name"
              class="input-glass"
            />
          </label>

          <label class="block">
            <span class="sr-only">E-Mail</span>
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              placeholder="E-Mail"
              class="input-glass"
            />
          </label>

          <label class="block">
            <span class="sr-only">Telefon</span>
            <input
              type="tel"
              name="telefon"
              required
              autocomplete="tel"
              inputmode="tel"
              placeholder="Telefon"
              class="input-glass"
            />
          </label>

          <label class="block">
            <span class="sr-only">Nachricht</span>
            <textarea
              name="nachricht"
              rows="3"
              placeholder="Worum geht es? (z.B. Büroreinigung, 200 m², wöchentlich)"
              class="input-glass resize-none"
            ></textarea>
          </label>
        </div>

        <label class="mt-4 flex items-start gap-3 text-xs leading-relaxed text-white/65">
          <input type="checkbox" required name="datenschutz" class="mt-0.5 h-4 w-4 rounded border-white/20 bg-white/10 text-ig-emerald focus:ring-ig-emerald" />
          <span>
            Ich stimme der Verarbeitung meiner Daten gemäß
            <a href="/datenschutz" class="underline hover:text-ig-emerald">Datenschutzerklärung</a> zu.
          </span>
        </label>

        <button
          type="submit"
          class="btn-primary mt-5 w-full py-4 text-base"
          data-form="hero"
        >
          Unverbindlich anfragen
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </button>

        <p class="mt-3 text-center text-xs text-white/45">
          Keine Weitergabe an Dritte. Antwort in der Regel binnen 24 Std.
        </p>
      </form>
    </div>

  </div>
</section>
