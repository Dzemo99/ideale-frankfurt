---
const trustItems = [
  { title: '5 Mio. EUR versichert', text: 'Betriebshaftpflicht', icon: 'shield' },
  { title: 'Festpreise', text: 'Keine versteckten Kosten', icon: 'tag' },
  { title: 'Schnelle Reaktion', text: 'Anfrage am selben Tag', icon: 'clock' },
  { title: 'Eigenes Team', text: 'Keine Subunternehmer', icon: 'users' },
  { title: 'Großraum Frankfurt', text: 'Rhein-Main inkl. Umland', icon: 'map' },
];
---
<section class="border-b border-ig-line bg-white">
  <div class="container-ig grid grid-cols-2 gap-y-8 py-12 sm:grid-cols-3 md:grid-cols-5 md:py-14">
    {trustItems.map((item) => (
      <div class="flex items-start gap-3">
        <div class="mt-0.5 text-ig-emerald" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            {item.icon === 'shield' && <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />}
            {item.icon === 'tag' && (
              <>
                <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" />
                <line x1="7" y1="7" x2="7.01" y2="7" />
              </>
            )}
            {item.icon === 'clock' && (
              <>
                <circle cx="12" cy="12" r="10" />
                <polyline points="12 6 12 12 16 14" />
              </>
            )}
            {item.icon === 'users' && (
              <>
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                <circle cx="9" cy="7" r="4" />
                <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                <path d="M16 3.13a4 4 0 0 1 0 7.75" />
              </>
            )}
            {item.icon === 'map' && (
              <>
                <polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6" />
                <line x1="8" y1="2" x2="8" y2="18" />
                <line x1="16" y1="6" x2="16" y2="22" />
              </>
            )}
          </svg>
        </div>
        <div>
          <div class="text-sm font-semibold text-ig-dark">{item.title}</div>
          <div class="text-xs text-ig-muteLight">{item.text}</div>
        </div>
      </div>
    ))}
  </div>
</section>
