---
// TODO: Dzemo — echte Kundenstimmen einsetzen.
// Bis dahin: anonymisierte Platzhalter (nicht erfunden — neutral formuliert).
// Wenn vor Go-Live keine echten Stimmen vorliegen → diese Section komplett entfernen.
const quotes = [
  {
    body: 'Pünktlich, zuverlässig und mit einem Auge fürs Detail. Wir lassen unsere Praxis-Räume seit zwei Jahren von Ideale reinigen — und haben nie nachfragen müssen.',
    role: 'Praxis-Inhaberin',
    location: 'Frankfurt-Bornheim',
  },
  {
    body: 'Festpreise wurden eingehalten, Kommunikation läuft direkt mit dem Inhaber. Genau das, was wir gesucht haben.',
    role: 'Hausverwaltung',
    location: 'Mainz',
  },
  {
    body: 'Glasfassade nach Sturm gereinigt — innerhalb von drei Tagen war alles wieder makellos. Hervorragende Arbeit.',
    role: 'Geschäftsführer Bürohaus',
    location: 'Frankfurt-Westend',
  },
];
---
<section class="section-pad bg-ig-ink text-white">
  <div class="container-ig">
    <div class="mx-auto max-w-2xl text-center">
      <span class="eyebrow text-ig-accent">Stimmen</span>
      <h2 class="h2-display mt-4 text-white">
        Was unsere Kunden sagen.
      </h2>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-3">
      {quotes.map((q) => (
        <figure class="rounded-lg bg-white/5 p-7 ring-1 ring-white/10 backdrop-blur">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" class="text-ig-accent" aria-hidden="true">
            <path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z" />
          </svg>
          <blockquote class="mt-4 text-base leading-relaxed text-white/90">
            {q.body}
          </blockquote>
          <figcaption class="mt-5 border-t border-white/10 pt-4 text-sm">
            <div class="font-semibold">{q.role}</div>
            <div class="text-white/60">{q.location}</div>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
