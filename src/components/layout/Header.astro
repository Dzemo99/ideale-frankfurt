---
import { SITE } from '../../data/site';
---
<header
  id="site-header"
  class="sticky top-0 z-40 border-b border-white/0 bg-ig-ink/80 text-white backdrop-blur-md transition-all duration-200 on-dark"
>
  <div class="container-ig flex h-16 items-center justify-between md:h-20">
    <a href="/" class="flex items-center gap-3" aria-label={`${SITE.name} — Startseite`}>
      <img src="/images/logo.svg" alt="" width="36" height="36" class="h-9 w-9 brightness-0 invert" />
      <span class="hidden font-display text-base font-bold tracking-tight text-white sm:inline">
        Ideale <span class="text-ig-emerald">Gebäudereinigung</span>
      </span>
    </a>

    <nav class="flex items-center gap-2 md:gap-4">
      <a
        href={SITE.phoneLink}
        class="hidden items-center gap-2 text-sm font-semibold text-white/85 transition-colors hover:text-ig-emerald md:inline-flex"
        data-track="phone_click"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
        </svg>
        <span class="font-mono tracking-tight">{SITE.phoneDisplay}</span>
      </a>
      <a href="#rechner" class="btn-primary text-sm md:text-base">
        Preis berechnen
      </a>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  if (header) {
    const update = () => {
      if (window.scrollY > 8) header.classList.add('border-white/10', 'bg-ig-ink/95', 'shadow-lg');
      else header.classList.remove('border-white/10', 'bg-ig-ink/95', 'shadow-lg');
    };
    update();
    window.addEventListener('scroll', update, { passive: true });
  }

</script>
